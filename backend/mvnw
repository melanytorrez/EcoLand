# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup script for Unix, version 3.3.0
#
# Required ENV vars:
# JAVA_HOME - location of a JDK home dir
#
# Optional ENV vars
# MAVEN_OPTS - parameters passed to the Java VM when running Maven
#     e.g. to debug Maven itself, use
# set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
# ----------------------------------------------------------------------------

# Resolve any links
PRG="$0"
while [ -h "$PRG" ] ; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`/"$link"
  fi
done

PRGDIR=`dirname "$PRG"`
BASEDIR=`cd "$PRGDIR" >/dev/null ; pwd`

# For Cygwin, ensure paths are in UNIX format before anything is touched
if $cygwin ; then
  [ -n "$JAVA_HOME" ] && JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
fi

if [ -z "$JAVA_HOME" ] ; then
  if [ -x /usr/libexec/java_home ] ; then
    export JAVA_HOME=`/usr/libexec/java_home`
  fi
fi

if [ -z "$JAVA_HOME" ] ; then
  javaExecutable="`which java`"
  if [ -z "$javaExecutable" ] ; then
    echo "ERROR: JAVA_HOME not found in your environment." >&2
    echo "Please set the JAVA_HOME variable in your environment to match the" >&2
    echo "location of your Java installation." >&2
    exit 1
  fi
fi

WRAPPER_JAR="$BASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"
DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.0/maven-wrapper-3.3.0.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
    echo "Downloading Maven Wrapper..."
    if command -v wget >/dev/null 2>&1; then
        wget -O "$WRAPPER_JAR" "$DOWNLOAD_URL"
    elif command -v curl >/dev/null 2>&1; then
        curl -o "$WRAPPER_JAR" "$DOWNLOAD_URL"
    else
        echo "ERROR: Neither wget nor curl found. Please install one to download the wrapper." >&2
        exit 1
    fi
fi

exec "$JAVA_HOME/bin/java" $MAVEN_OPTS -classpath "$WRAPPER_JAR" "$WRAPPER_LAUNCHER" "$@"
